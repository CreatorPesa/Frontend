# Backend API (see the `backend` repository)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# Stellar network
NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC=https://soroban-testnet.stellar.org

# Deployed Soroban contract addresses (see the `contracts` repository)
NEXT_PUBLIC_ESCROW_CONTRACT_ID=
NEXT_PUBLIC_SPLITTER_CONTRACT_ID=
NEXT_PUBLIC_REGISTRY_CONTRACT_ID=

# Auth session cookie name issued by the backend after Google OAuth
NEXT_PUBLIC_SESSION_COOKIE_NAME=cp_session

# Server-only secret used to HMAC-sign each creator's OBS overlay URL so it
# can't be guessed or scraped. Never expose this with a NEXT_PUBLIC_ prefix.
OVERLAY_SIGNING_SECRET=
